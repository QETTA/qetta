# ============================================
# QETTA Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values
# Required variables are marked with [REQUIRED]
# ============================================

# === Core [REQUIRED] ===
# Claude AI API key - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# NextAuth.js secret (min 32 chars) - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-min-32-characters

# PostgreSQL connection string (Supabase, Neon, etc.)
DATABASE_URL=postgresql://user:password@host:5432/qetta

# === Payment (Toss) [REQUIRED for billing] ===
# Toss Payments API keys - https://developers.tosspayments.com/
TOSS_CLIENT_KEY=test_ck_xxxxxxxx
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxx
TOSS_WEBHOOK_SECRET=your-webhook-secret

# === Application URL ===
# Auto-detected on Vercel, set manually for other deployments
NEXT_PUBLIC_APP_URL=https://your-domain.com

# === OAuth Providers [Optional] ===
# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/callback/gmail

# GitHub OAuth - https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft/Outlook OAuth - https://portal.azure.com/
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://your-domain.com/api/auth/callback/outlook

# === Document Services [Optional] ===
# Hancom Docs API - https://docs.hancom.com/
HANCOM_CLIENT_ID=
HANCOM_CLIENT_SECRET=
HANCOM_REDIRECT_URI=http://localhost:3000/api/hancom/callback

# === Email Service [Optional] ===
# Resend - https://resend.com/
RESEND_API_KEY=re_xxxxxxxx

# === Cache & Queue [Optional] ===
# Upstash Redis - https://upstash.com/
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxx

# Standard Redis (for BullMQ workers)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# === Monitoring [Optional] ===
# Sentry - https://sentry.io/
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
SENTRY_ORG=your-org
SENTRY_PROJECT=qetta

# Logging level (debug, info, warn, error, silent)
LOG_LEVEL=info

# === External Data Sources [Optional] ===
# BizInfo (기업마당) API
BIZINFO_API_KEY=

# K-Startup API
K_STARTUP_API_KEY=

# SAM.gov (US Government) API
SAM_GOV_API_KEY=

# UNGM (UN Global Marketplace) API
UNGM_API_KEY=

# SBIZ24 API
SBIZ24_API_KEY=

# Goszakup (Kazakhstan) API
GOSZAKUP_API_KEY=

# === IoT/Monitor [Optional] ===
# MQTT Broker
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=qetta-monitor
MQTT_USE_TLS=false
MQTT_CA_CERT_PATH=

# OPC-UA Server
OPCUA_ENDPOINT_URL=opc.tcp://localhost:4840
OPCUA_SECURITY_MODE=SignAndEncrypt
OPCUA_SECURITY_POLICY=Basic256Sha256
OPCUA_USERNAME=
OPCUA_PASSWORD=
OPCUA_CERTIFICATE_PATH=
OPCUA_PRIVATE_KEY_PATH=

# === Feature Flags [Optional] ===
NEXT_PUBLIC_ENABLE_MONITOR_WIDGETS=true
NEXT_PUBLIC_API_URL=http://localhost:3000

# === Testing [Auto-set in CI] ===
# SKIP_ENV_VALIDATION=true
